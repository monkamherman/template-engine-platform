# Application
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template_engine_platform

# Authentication foundation
AUTH_SECRET=replace-with-a-long-random-development-secret

# Licensing and protected downloads
LICENSE_KEY_PEPPER=replace-with-a-long-random-development-secret
DOWNLOAD_SIGNING_SECRET=replace-with-a-long-random-development-secret

# Payment adapter (development placeholder only)
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=replace-with-provider-webhook-secret

# Private object storage (development placeholder only)
STORAGE_PROVIDER=mock
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=template-engine-releases-dev
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Transactional email (development placeholder only)
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.test
EMAIL_API_KEY=
