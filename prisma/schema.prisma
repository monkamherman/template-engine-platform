generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum Role {
  CUSTOMER
  SUPPORT
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OfferType {
  STARTER
  PRO
  MANAGED
}

enum BillingMode {
  ONE_TIME
  RECURRING
  MANUAL_CONTRACT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ProviderEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum EntitlementStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum EntitlementSource {
  PURCHASE
  MANUAL
  MIGRATION
  PROMOTION
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum LicenseActivationStatus {
  ACTIVE
  DEACTIVATED
  BLOCKED
}

enum LicenseActivationEnvironment {
  PRODUCTION
  STAGING
}

enum ReleaseChannel {
  STABLE
  EARLY_ACCESS
}

enum ReleaseStatus {
  DRAFT
  PUBLISHED
  DISABLED
}

enum ReleaseFileStatus {
  ACTIVE
  DISABLED
}

enum LegalDocumentType {
  SOFTWARE_LICENSE
  COMMERCIAL_TERMS
  SUPPORT_POLICY
  REFUNDS
  PRIVACY
  TRADEMARK
}

enum LegalDocumentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  name            String?
  emailVerified   DateTime?            @map("emailVerifiedAt")
  image           String?
  preferredLocale String               @default("fr")
  status          UserStatus           @default(ACTIVE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  accounts        Account[]
  sessions        Session[]
  password        PasswordCredential?
  magicLinks      AuthMagicLinkToken[]
  roles           UserRole[]
  orders          Order[]
  entitlements    Entitlement[]
  acceptances     CustomerAcceptance[]
  auditEvents     AuditEvent[]         @relation("AuditActor")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

model AuthMagicLinkToken {
  id         String    @id @default(cuid())
  userId     String?
  email      String
  purpose    String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([purpose, tokenHash])
  @@index([email, purpose, expiresAt])
  @@index([userId, purpose])
  @@map("auth_magic_link_tokens")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  offers      Offer[]
  releases    Release[]

  @@map("products")
}

model Offer {
  id              String              @id @default(cuid())
  productId       String
  code            String              @unique
  name            String
  type            OfferType
  billingMode     BillingMode
  activationLimit Int
  supportPolicy   String?
  updatePolicy    String?
  status          ProductStatus       @default(DRAFT)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  product         Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  prices          Price[]
  orderItems      OrderItem[]
  entitlements    Entitlement[]
  termsVersions   OfferTermsVersion[]

  @@map("offers")
}

model Price {
  id              String    @id @default(cuid())
  offerId         String
  currency        String
  amountMinor     Int
  billingInterval String?
  provider        String?
  providerPriceId String?
  active          Boolean   @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  offer           Offer     @relation(fields: [offerId], references: [id], onDelete: Restrict)

  @@unique([provider, providerPriceId])
  @@index([offerId, currency, active])
  @@map("prices")
}

model Order {
  id              String               @id @default(cuid())
  number          String               @unique
  userId          String?
  email           String
  status          OrderStatus          @default(PENDING)
  subtotalMinor   Int
  discountMinor   Int                  @default(0)
  taxMinor        Int                  @default(0)
  totalMinor      Int
  currency        String
  billingSnapshot Json?
  paidAt          DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        Payment[]
  acceptances     CustomerAcceptance[]

  @@map("orders")
}

model OrderItem {
  id                  String        @id @default(cuid())
  orderId             String
  offerId             String
  offerNameSnapshot   String
  offerPolicySnapshot Json?
  quantity            Int
  unitAmountMinor     Int
  totalAmountMinor    Int
  createdAt           DateTime      @default(now())
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  offer               Offer         @relation(fields: [offerId], references: [id], onDelete: Restrict)
  entitlements        Entitlement[]

  @@map("order_items")
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(PENDING)
  amountMinor       Int
  currency          String
  paidAt            DateTime?
  failureCode       String?
  failureMessage    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([provider, providerPaymentId])
  @@map("payments")
}

model ProviderEvent {
  id              String              @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  status          ProviderEventStatus @default(RECEIVED)
  metadata        Json?
  error           String?
  receivedAt      DateTime            @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId])
  @@map("provider_events")
}

model Entitlement {
  id                String            @id @default(cuid())
  userId            String
  sourceOrderItemId String?
  offerId           String
  status            EntitlementStatus @default(ACTIVE)
  source            EntitlementSource @default(PURCHASE)
  startsAt          DateTime          @default(now())
  endsAt            DateTime?
  updateExpiresAt   DateTime?
  supportExpiresAt  DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  sourceOrderItem   OrderItem?        @relation(fields: [sourceOrderItemId], references: [id], onDelete: SetNull)
  offer             Offer             @relation(fields: [offerId], references: [id], onDelete: Restrict)
  license           License?

  @@map("entitlements")
}

model License {
  id                   String              @id @default(cuid())
  entitlementId        String              @unique
  keyPrefix            String
  keyLast4             String
  secretHash           String
  secretCiphertext     String
  secretNonce          String
  secretAuthTag        String
  encryptionKeyVersion String
  hashVersion          String
  keyVersion           Int                 @default(1)
  status               LicenseStatus       @default(ACTIVE)
  productionLimit      Int                 @default(1)
  stagingLimit         Int                 @default(1)
  issuedAt             DateTime            @default(now())
  expiresAt            DateTime?
  lastValidatedAt      DateTime?
  revokedAt            DateTime?
  entitlement          Entitlement         @relation(fields: [entitlementId], references: [id], onDelete: Restrict)
  activations          LicenseActivation[]

  @@unique([keyPrefix, secretHash])
  @@index([keyPrefix])
  @@index([status])
  @@map("licenses")
}

model LicenseActivation {
  id                  String                       @id @default(cuid())
  licenseId           String
  installationId      String
  environment         LicenseActivationEnvironment
  normalizedDomain    String
  siteUrl             String?
  status              LicenseActivationStatus      @default(ACTIVE)
  environmentMetadata Json?
  activatedAt         DateTime                     @default(now())
  lastSeenAt          DateTime?
  deactivatedAt       DateTime?
  license             License                      @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, installationId])
  @@index([licenseId, status])
  @@index([licenseId, environment, status])
  @@map("license_activations")
}

model Release {
  id           String         @id @default(cuid())
  productId    String
  version      String
  channel      ReleaseChannel @default(STABLE)
  status       ReleaseStatus  @default(DRAFT)
  changelog    String?
  requirements Json?
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  product      Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  files        ReleaseFile[]

  @@unique([productId, version])
  @@map("releases")
}

model ReleaseFile {
  id              String            @id @default(cuid())
  releaseId       String
  storageProvider String
  bucket          String
  objectKey       String
  fileName        String
  fileType        String
  fileSize        Int
  checksumSha256  String
  status          ReleaseFileStatus @default(ACTIVE)
  createdAt       DateTime          @default(now())
  release         Release           @relation(fields: [releaseId], references: [id], onDelete: Restrict)

  @@unique([storageProvider, bucket, objectKey])
  @@map("release_files")
}

model AuditEvent {
  id            String   @id @default(cuid())
  actorUserId   String?
  action        String
  targetType    String
  targetId      String
  summary       Json?
  reason        String?
  correlationId String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@map("audit_events")
}

model LegalDocument {
  id        String                 @id @default(cuid())
  type      LegalDocumentType
  slug      String
  locale    String
  title     String
  owner     String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  versions  LegalDocumentVersion[]

  @@unique([type, locale])
  @@unique([slug, locale])
  @@map("legal_documents")
}

model LegalDocumentVersion {
  id              String               @id @default(cuid())
  documentId      String
  version         String
  status          LegalDocumentStatus  @default(DRAFT)
  effectiveAt     DateTime?
  contentChecksum String
  reviewNotes     String?
  createdAt       DateTime             @default(now())
  publishedAt     DateTime?
  archivedAt      DateTime?
  document        LegalDocument        @relation(fields: [documentId], references: [id], onDelete: Restrict)
  offerTerms      OfferTermsVersion[]
  acceptances     CustomerAcceptance[]

  @@unique([documentId, version])
  @@index([documentId, status])
  @@map("legal_document_versions")
}

model OfferTermsVersion {
  id                     String               @id @default(cuid())
  offerId                String
  legalDocumentVersionId String
  version                String
  status                 LegalDocumentStatus  @default(DRAFT)
  effectiveAt            DateTime?
  contentChecksum        String
  createdAt              DateTime             @default(now())
  offer                  Offer                @relation(fields: [offerId], references: [id], onDelete: Restrict)
  legalDocumentVersion   LegalDocumentVersion @relation(fields: [legalDocumentVersionId], references: [id], onDelete: Restrict)
  acceptances            CustomerAcceptance[]

  @@unique([offerId, version])
  @@index([offerId, status])
  @@map("offer_terms_versions")
}

model CustomerAcceptance {
  id                     String               @id @default(cuid())
  userId                 String?
  orderId                String?
  legalDocumentVersionId String
  offerTermsVersionId    String?
  acceptedAt             DateTime             @default(now())
  acceptanceContext      Json?
  user                   User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  order                  Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  legalDocumentVersion   LegalDocumentVersion @relation(fields: [legalDocumentVersionId], references: [id], onDelete: Restrict)
  offerTermsVersion      OfferTermsVersion?   @relation(fields: [offerTermsVersionId], references: [id], onDelete: SetNull)

  @@index([userId, acceptedAt])
  @@index([orderId])
  @@map("customer_acceptances")
}
